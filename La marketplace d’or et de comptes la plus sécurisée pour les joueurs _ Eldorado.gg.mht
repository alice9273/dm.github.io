#primer-checkout-other-payment-methods.PrimerCheckout--entering, #primer-checkout-other-payment-methods.PrimerCheckout--entered { opacity: 1; visibility: visible; width: auto; }

#primer-checkout-payment-method-divider { opacity: 1; transition: 0.5s cubic-bezier(0.4, 0, 0.2, 1); }

#primer-checkout-payment-method-divider.PrimerCheckout--exit { opacity: 0; height: 0px; margin-bottom: 0px; }
