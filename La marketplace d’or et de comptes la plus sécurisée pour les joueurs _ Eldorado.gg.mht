.card { position: relative; display: flex; -webkit-box-orient: vertical; flex-direction: column; min-width: 0px; background-color: var(--background-base-1); background-clip: border-box; box-shadow: var(--shadow-alt-1); }

.card .card-body { padding: 2.25rem; }

.card .card-row { padding: 1.5rem 2.25rem; border-bottom: 1px solid var(--divider-border); }

.card.card-hidden { display: none; }

.card-header, .card-bottom { min-height: 50px; display: flex; align-items: center; padding: 18px 12px; font-size: 16px; background-color: var(--background-alt-1); border-top: 1px solid var(--divider-border); }

.card-header i, .card-bottom i { font-size: 19px; margin-right: 11px; }

.card-header.flex-end i, .card-bottom.flex-end i { margin-left: 11px; margin-right: 0px; }

.nsm-content { background-color: var(--background-base-1); }

.custom-modal { max-width: 648px; }

.custom-modal h4, .custom-modal h5 { padding-bottom: 15px; padding-right: 30px; color: var(--text-primary); }

.custom-modal h3, .custom-modal h6, .custom-modal strong { color: var(--text-primary); }

.custom-modal p { margin: 25px 0px; font-size: 14px; line-height: 16.8px; color: var(--text-primary); }

.custom-modal .nsm-dialog-btn-close { top: 22px; right: 24px; color: var(--text-primary); }

.custom-modal .nsm-content { width: 100%; background-color: var(--background-base-1); border-top: 1px solid var(--divider-border); border-radius: 4px; }

.custom-modal .modal-buttons { display: flex; justify-content: flex-end; }

.large-modal { padding-top: 100px; }

.with-sidebar-modal { padding-left: 250px; }

.fit-content-modal { justify-content: center; }

.fit-content-modal .nsm-content { width: auto; }

.full-screen-modal .nsm-content { max-width: 100vw; max-height: 100dvh; border-radius: 14px; padding: 0px; }

@media (max-width: 960px) {
  .full-screen-modal .nsm-content { min-width: 100vw; min-height: 100dvh; margin: 0px; border-radius: 0px; }
}

.full-screen-modal .nsm-content .nsm-body { min-height: 0px; display: flex; flex-direction: column; }

.offer-full-details-modal { max-width: 775px; }

.offer-full-details-modal h4 { margin-bottom: 0px; font-size: 24px; line-height: 26px; color: var(--text-primary); }

ngx-smart-modal .overlay:has(> .global-search-modal) { transition-duration: 0.2s; transition-timing-function: ease-in; }

ngx-smart-modal .overlay:has(> .global-search-modal) .global-search-modal { transition-duration: 0.2s; transition-timing-function: ease-in; transition-property: opacity; }

.global-search-modal { width: var(--container-primary-width); max-width: 100%; padding-inline: 24px; }

@media (max-width: 960px) {
  .global-search-modal { padding-inline: 0px; }
}

.global-search-modal .nsm-content { max-height: 530px; margin-top: 12px; max-width: 100%; margin-inline: 0px; }

@media (max-width: 960px) {
  .global-search-modal .nsm-content { margin-top: 0px; }
}

.payment-details-modal { max-width: 856px; }

.payment-details-modal p { margin: 0px; }

.order-page-modal { max-width: 870px; }

.value-proposition-modal .nsm-content { border-radius: var(--corner-large); padding: 26px 24px 36px; }

.vote-for-feature-modal { width: fit-content; max-width: 100%; }

.vote-for-feature-modal .nsm-dialog-btn-close { top: 22px; right: 24px; color: var(--text-primary); }

.vote-for-feature-modal .nsm-content { width: 100%; padding: 0px; background-color: var(--background-base-1); border-top: 1px solid var(--divider-border); border-radius: var(--corner-3xl); }

@media (max-width: 1024px) {
  .custom-modal:not(.fit-content-modal, .global-search-modal) .nsm-content { width: 90%; }
  .with-sidebar-modal { padding-left: 0px; }
  .user-verification-modal { max-width: 976px; }
}

.dialog-open eld-modal ngx-smart-modal .overlay { backdrop-filter: blur(4px); }

eld-modal ngx-smart-modal { display: block; }

eld-modal ngx-smart-modal .overlay { display: flex; align-items: center; }

eld-modal ngx-smart-modal .nsm-dialog { max-height: 100vh; }

eld-modal ngx-smart-modal .modal-size-s.nsm-dialog { max-width: 620px; padding: 0px 10px; }

eld-modal ngx-smart-modal .modal-size-m.nsm-dialog { max-width: 760px; padding: 0px 10px; }

eld-modal ngx-smart-modal .modal-size-l.nsm-dialog { max-width: 1012px; padding: 0px 10px; }

eld-modal ngx-smart-modal .nsm-content { background: var(--background-base-1); margin: 0px; padding: 1.5rem; border-radius: var(--corner-large); width: 100%; max-width: 100%; }

eld-modal ngx-smart-modal hr { background: var(--divider-border); height: 1px; border: 0px; }

eld-modal ngx-smart-modal .nsm-dialog-btn-close { display: none; }

@media (max-width: 600px) {
